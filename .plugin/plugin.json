{
  "name": "github-copilot-agent-plugin",
  "version": "1.0.0",
  "displayName": "GitHub Copilot Agent Plugin",
  "description": "A collection of reusable GitHub Copilot agent customizations for code review, documentation, and development workflows",
  "publisher": "djredman99-org",
  "repository": {
    "type": "git",
    "url": "https://github.com/djredman99-org/github-agentic-workflows"
  },
  "categories": [
    "Agent Customizations",
    "Code Review",
    "Documentation",
    "Development Tools"
  ],
  "keywords": [
    "copilot",
    "agent",
    "code-review",
    "documentation",
    "refactoring",
    "python"
  ],
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "copilot": ">=1.0.0"
  },
  "contributes": {
    "agents": [
      {
        "name": "doc-writer",
        "file": ".github/agents/doc-writer.agent.md",
        "description": "Documentation generation specialist"
      }
    ],
    "skills": [
      {
        "name": "code-review",
        "file": ".github/skills/code-review/SKILL.md",
        "description": "Comprehensive code review with security and quality checks"
      }
    ],
    "instructions": [
      {
        "name": "python-standards",
        "file": ".github/instructions/python-standards.instructions.md",
        "description": "Python best practices and standards"
      }
    ],
    "prompts": [
      {
        "name": "refactor",
        "file": ".github/prompts/refactor.prompt.md",
        "description": "Code refactoring guidance"
      }
    ]
  }
}
